# =============================================================================
# qndb — Quantum Database Configuration
# =============================================================================
# Copy this file to `.env` in your project root and fill in the values you need.
# qndb.configure() will load it automatically.
#
# Only uncomment the backends you intend to use.  All backends fall back
# to the local Cirq simulator when credentials are absent.
# =============================================================================

# --- IBM Quantum (Qiskit Runtime) -------------------------------------------
# Get your token at https://quantum.ibm.com/
# QNDB_IBM_ENABLED=1
# QNDB_IBM_API_KEY=your-ibm-quantum-api-token

# --- IonQ (Trapped-Ion Cloud) -----------------------------------------------
# Get your key at https://cloud.ionq.com/settings/keys
# QNDB_IONQ_ENABLED=1
# QNDB_IONQ_API_KEY=your-ionq-api-key

# --- Google Quantum AI ------------------------------------------------------
# Uses standard GCP service-account auth.
# Set GOOGLE_APPLICATION_CREDENTIALS to the JSON key file path.
# QNDB_GOOGLE_ENABLED=1
# QNDB_GOOGLE_PROJECT_ID=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# --- Amazon Braket ----------------------------------------------------------
# Uses standard AWS credential chain (env vars, ~/.aws/credentials, IAM role).
# QNDB_BRAKET_ENABLED=1
# QNDB_BRAKET_DEVICE_ARN=arn:aws:braket:us-east-1::device/qpu/ionq/Aria-1
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_DEFAULT_REGION=us-east-1

# --- Master hardware switch -------------------------------------------------
# Set to 1 to enable hardware backends globally.
# This is set automatically by qndb.configure() when any key is provided.
# QNDB_HARDWARE_ENABLED=1
